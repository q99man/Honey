#!/usr/bin/env bash
set -e

if [ -d /usr/bin ]; then
  export PATH="/usr/bin:$PATH"
fi

if [ -n "$JAVA_HOME" ]; then
  export PATH="$JAVA_HOME/bin:$PATH"
fi

if ! command -v java >/dev/null 2>&1; then
  for candidate in \
    "/c/Program Files/Java/jdk-21.0.10" \
    "/c/Program Files/Java/jdk-21" \
    "/c/Program Files/Eclipse Adoptium/jdk-21.0.10.9-hotspot" \
    "/c/Program Files/Eclipse Adoptium/jdk-21.0.8.9-hotspot"
  do
    if [ -x "$candidate/bin/java" ]; then
      export JAVA_HOME="$candidate"
      export PATH="$JAVA_HOME/bin:$PATH"
      break
    fi
  done
fi

if ! command -v java >/dev/null 2>&1; then
  echo "ERROR: java command could not be found."
  echo "JAVA_HOME=$JAVA_HOME"
  echo "PATH=$PATH"
  echo "GitHub Desktop could not see Java. Please restart GitHub Desktop or set JAVA_HOME."
  exit 1
fi

"${BASH:-bash}" ./scripts/format-check.sh
"${BASH:-bash}" ./scripts/verify-doc-sync.sh
"${BASH:-bash}" ./scripts/check-korean-encoding.sh
"${BASH:-bash}" ./scripts/verify-ui-language.sh