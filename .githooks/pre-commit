#!/usr/bin/env bash
set -e

if [ -d /usr/bin ]; then
  export PATH="/usr/bin:$PATH"
fi

if [ -z "$JAVA_HOME" ] && [ -d "/c/Program Files/Java/jdk-21.0.10" ]; then
  export JAVA_HOME="/c/Program Files/Java/jdk-21.0.10"
fi

if [ -n "$JAVA_HOME" ]; then
  export PATH="$JAVA_HOME/bin:$PATH"
fi

if ! command -v java >/dev/null 2>&1; then
  echo "ERROR: java command could not be found."
  echo "JAVA_HOME=$JAVA_HOME"
  echo "Please set JAVA_HOME and add JAVA_HOME/bin to PATH."
  exit 1
fi

"${BASH:-bash}" ./scripts/format-check.sh
"${BASH:-bash}" ./scripts/verify-doc-sync.sh
"${BASH:-bash}" ./scripts/check-korean-encoding.sh
"${BASH:-bash}" ./scripts/verify-ui-language.sh