DB_URL=jdbc:mysql://localhost:3306/honey?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=
DB_PASSWORD=
JWT_SECRET=dev-only-honeytong-jwt-secret-key-must-be-replaced

KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
VITE_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
VITE_API_BASE_URL=http://localhost:8080

# Optional overrides
SPRING_PROFILES_ACTIVE=
FLYWAY_ENABLED=false
FLYWAY_LOCATIONS=classpath:db/migration
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_VALIDATE_ON_MIGRATE=true
CACHE_TYPE=none
APP_REDIS_ENABLED=false
POLICY_CACHE_TTL=10m
RANKING_CACHE_TTL=5m
RANKING_SCHEDULER_ENABLED=false
RANKING_SCHEDULER_CRON=0 0 4 * * *
RANKING_SCHEDULER_ZONE=Asia/Seoul
RANKING_SCHEDULER_SEASON_CODE=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
REDIS_HEALTH_ENABLED=false
MAP_PROVIDER=kakao
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com
REGION_SEED_ENABLED=false
REGION_SEED_LOCATION=classpath:region/region-seed.csv
POLICY_SEED_ENABLED=false
POLICY_SEED_LOCATION=classpath:policy/policy-defaults.csv

# Local development only: creates/promotes a LOCAL admin account on backend startup.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-local-password
ADMIN_BOOTSTRAP_NICKNAME=local-admin
ADMIN_BOOTSTRAP_ROLE=SUPER_ADMIN
ADMIN_BOOTSTRAP_PHONE=
ADMIN_BOOTSTRAP_PHONE_VERIFIED=true
ADMIN_BOOTSTRAP_RESET_PASSWORD=false

# Production baseline
# Set SPRING_PROFILES_ACTIVE=prod in production.
# Required production variables: DB_URL, DB_USERNAME, DB_PASSWORD, JWT_SECRET.
# Production defaults keep JPA schema auto-update disabled with JPA_DDL_AUTO=validate unless explicitly overridden.
# Production defaults enable Flyway with FLYWAY_ENABLED=true from application-prod.yml.
